generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(ROLE_USER)
  accounts      Account[]
  sessions      Session[]
  searchHistory SearchHistory[]
  playlists     Playlist[]
  created_at    DateTime  @default(now())
}

enum Role {
  ROLE_USER
  ROLE_ADMIN
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  email             String? // 해당 provider에서 제공한 이메일
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

model OAuthState {
  id           String   @id @default(cuid())
  mode         String   // 'login' | 'link'
  userId       String?  // link 모드에서만 사용
  provider     String
  codeVerifier String
  callbackUrl  String   @default("/")
  expiresAt    DateTime
  createdAt    DateTime @default(now())
}

model Song {
  id              String       @id @default(cuid())
  genius_id       String       @unique
  title           String
  artist          String
  image_url       String?
  genius_path     String
  album           String?
  album_image_url String?
  release_date    String?
  description     String?      @db.Text
  description_ko  String?      @db.Text
  spotify_url     String?
  youtube_url     String?
  apple_music_url String?
  genius_artist_id  String?
  genius_album_id   String?
  featured_artists  Json?        // Array<{id:string, name:string}>
  lyrics_status     LyricsStatus @default(NONE)
  locked_at        DateTime?
  generation_id    String?
  created_at       DateTime     @default(now())

  raw           SongLyricsRaw?
  lines         LyricLine[]
  playlistSongs PlaylistSong[]

  @@index([genius_artist_id])
  @@index([genius_album_id])
}

model SongLyricsRaw {
  id          String   @id @default(cuid())
  song_id     String   @unique
  raw_text    String   @db.Text
  annotations Json?
  scraped_at  DateTime @default(now())
  song        Song     @relation(fields: [song_id], references: [id], onDelete: Cascade)
}

model LyricLine {
  id            String  @id @default(cuid())
  song_id       String
  line_number   Int
  original      String
  translation   String?
  slang         String? @db.Text
  explanation   String? @db.Text
  generation_id String
  song          Song    @relation(fields: [song_id], references: [id], onDelete: Cascade)

  @@unique([song_id, line_number])
}

model SearchHistory {
  id         String   @id @default(cuid())
  userId     String
  genius_id  String
  title      String
  artist     String
  image_url  String?
  created_at DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, genius_id])
  @@index([userId])
}

model Playlist {
  id        String         @id @default(cuid())
  userId    String
  name      String
  isDefault Boolean        @default(false)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  songs     PlaylistSong[]

  @@unique([userId, name])
  @@index([userId])
}

model PlaylistSong {
  id         String   @id @default(cuid())
  playlistId String
  songId     String
  position   Int
  addedAt    DateTime @default(now())
  playlist   Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  song       Song     @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@unique([playlistId, songId])
  @@index([playlistId, position])
}

enum LyricsStatus {
  NONE
  PROCESSING
  DONE
  FAILED
}
